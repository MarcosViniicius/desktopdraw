{
  "name": "desktopdraw",
  "version": "0.0.1",
  "description": "Excalidraw desktop application built with React and Electron",
  "author": "Your Name <your.email@example.com>",
  "private": true,
  "type": "module",
  "main": "./electron/main.cjs",
  "scripts": {
    "dev:desktop": "concurrently -k \"react-router dev\" \"wait-on http://localhost:5173 && cross-env ELECTRON_START_URL=http://localhost:5173 electron ./electron/main.cjs\"",
    "build": "react-router build",
    "start": "npm run build && concurrently -k \"react-router-serve ./build/server/index.js --port 3000\" \"wait-on http://localhost:3000 && cross-env ELECTRON_START_URL=http://localhost:3000 electron ./electron/main.cjs\"",
    "typecheck": "react-router typegen && tsc",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "build:all": "npm run build && electron-builder -mwl"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "@react-router/node": "7.13.2",
    "@react-router/serve": "7.13.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "isbot": "^5.1.36",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "7.13.2",
    "wait-on": "^9.0.4"
  },
  "devDependencies": {
    "@react-router/dev": "7.13.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "electron": "^41.1.0",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "build": {
    "appId": "com.desktopdraw.app",
    "productName": "DesktopDraw",
    "buildDependenciesFromSource": false,
    "nodeGypRebuild": false,
    "files": [
      "build/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "public",
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "ia32"]
        },
        "portable"
      ],
      "icon": "public/favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "public/favicon.ico"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "public/favicon.ico",
      "category": "Graphics"
    }
  }
}
